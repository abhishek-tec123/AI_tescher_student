GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
GEMINI_LLM="gemini-2.5-flash-lite"
GROQ_LLM="meta-llama/llama-4-scout-17b-16e-instruct"
TAVILY_API_KEY=your-tavily-api-key-here
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"
DB_NAME=tutor_ai
AES_KEY=your-aes-key-here
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=180
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=https://yourdomain.com
APP_NAME="Student Learning API"
DEBUG=false
ENVIRONMENT=production
EMBED_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
TTS_DEFAULT_VOICE="en-US-AriaNeural"
RATE_LIMIT_ADMIN_REQUESTS=120
RATE_LIMIT_TEACHER_REQUESTS=120
RATE_LIMIT_DEFAULT_REQUESTS=300
RATE_LIMIT_WINDOW=60
